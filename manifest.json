{
  "manifest_version": 3,
  "name": "StarHUB Hypesquad Manager",
  "version": "1.2",
  "description": "Discord HypeSquad Add And Remove!",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.discord.com/*",
    "*://discord.com/*",
    "*://*.discordapp.com/*",
    "*://discordapp.com/*"
  ]
}